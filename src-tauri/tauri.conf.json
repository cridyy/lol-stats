{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "lol-stats",
  "version": "0.5.1",
  "identifier": "com.local.lolstats",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "国服战绩分析",
        "width": 1363,
        "height": 836,
        "minWidth": 1040,
        "minHeight": 680
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "windows": {
      "nsis": {
        "languages": ["SimpChinese"],
        "customLanguageFiles": {
          "SimpChinese": "nsis/SimpChinese.nsh"
        }
      }
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
